# ══════════════════════════════════════════════════
# TeleDrive Configuration
# ══════════════════════════════════════════════════

# --- Telegram API (get from https://my.telegram.org) ---
TG_API_ID=your_api_id
TG_API_HASH=your_api_hash
TG_PHONE=+1234567890
TG_SESSION_NAME=scraper_session

# --- Google Sheets (service account JSON file path) ---
GOOGLE_CREDS_JSON=your-service-account.json
SHEET_ID=your_google_sheet_id

# --- Flask ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
FLASK_DEBUG=1
FLASK_ENV=development
COOKIE_SECURE=false

# --- Server ---
PORT=5000
# CORS_ORIGIN=https://yourdomain.com

# ══════════════════════════════════════════════════
# PRODUCTION (Hetzner VPS / Ubuntu)
# ══════════════════════════════════════════════════
# For production deployment, set:
#   SECRET_KEY=<run: python3 -c "import secrets; print(secrets.token_hex(32))">
#   FLASK_DEBUG=0
#   FLASK_ENV=production
#   COOKIE_SECURE=true
#   PORT=5000  (Nginx proxies port 80/443 to this)
#
# The deploy.sh script generates SECRET_KEY automatically.
